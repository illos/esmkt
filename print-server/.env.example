# ─── Esmeralda Market — Print Server config ─────────────────────────────────
# Copy this file to .env and fill in the values. The server reads .env
# automatically on startup (no dotenv dependency).

# REQUIRED: where to reach the website API.
# Use the production URL once you're ready, or the *.pages.dev staging URL
# while you're testing.
API_BASE_URL=https://esmeraldamarket.com

# REQUIRED: the shared secret. Must match the value set on Cloudflare:
#   wrangler pages secret put PRINT_SERVER_SECRET --project-name esmeralda-market
PRINT_SERVER_SECRET=replace-with-a-long-random-string

# OPTIONAL: target a specific printer by name. If unset, uses the system
# default. Run `node server.js --list-printers` to see installed printers.
# PRINTER_NAME=EPSON TM-T20III

# OPTIONAL: cadence overrides (defaults shown).
# POLL_INTERVAL_MS=5000          # how often to check for new orders
# HEARTBEAT_INTERVAL_MS=30000    # how often to ping the website
# UPDATER_INTERVAL_MS=600000     # how often to git-fetch (0 = disable auto-update)

# OPTIONAL: chime command. Leave default for the ALSA "Front_Center" beep.
# Set to empty string to disable.
# CHIME_CMD=aplay -q /usr/share/sounds/alsa/Front_Center.wav
# CHIME_CMD=paplay /usr/share/sounds/freedesktop/stereo/message.oga
# CHIME_CMD=

# OPTIONAL: branch to track for auto-update (default 'main').
# GIT_BRANCH=main

# OPTIONAL: where to write the local NDJSON order log. Default ./orders.log.
# LOG_FILE=/var/log/esmkt-print/orders.log
