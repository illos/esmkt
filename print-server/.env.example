# ─── Esmeralda Market — Print Server config ─────────────────────────────────
# Copy this file to .env and fill in the values. The server reads .env
# automatically on startup (no dotenv dependency).

# REQUIRED: where to reach the website API.
# Use the production URL once you're ready, or the *.pages.dev staging URL
# while you're testing.
API_BASE_URL=https://esmeraldamarket.com

# REQUIRED: the shared secret. Must match the value set on Cloudflare:
#   wrangler pages secret put PRINT_SERVER_SECRET --project-name esmeralda-market
PRINT_SERVER_SECRET=replace-with-a-long-random-string

# OPTIONAL: target a specific printer by name. If unset, uses the system
# default. Run `node server.js --list-printers` to see installed printers.
# PRINTER_NAME=EPSON TM-T20III

# OPTIONAL: cadence overrides (defaults shown).
# POLL_INTERVAL_MS=5000          # how often to check for new orders
# HEARTBEAT_INTERVAL_MS=30000    # how often to ping the website
# UPDATER_INTERVAL_MS=600000     # how often to git-fetch (0 = disable auto-update)

# OPTIONAL: order chime — played for each newly-printed customer order.
# Default uses ALSA "Front_Center.wav". Set to empty string to disable.
# CHIME_CMD=aplay -q /usr/share/sounds/alsa/Front_Center.wav
# CHIME_CMD=paplay /usr/share/sounds/freedesktop/stereo/message.oga
# CHIME_CMD=

# OPTIONAL: printer-error chime — fires once when the printer transitions
# from ready → unready (out of paper, jam, cover open, etc.), then again
# every PRINTER_ERROR_CHIME_INTERVAL_MS while it stays unready. More urgent
# default sound than the order chime.
# PRINTER_ERROR_CHIME_CMD=paplay /usr/share/sounds/freedesktop/stereo/dialog-warning.oga
# PRINTER_ERROR_CHIME_CMD=
# PRINTER_ERROR_CHIME_INTERVAL_MS=180000     # 3 minutes; 0 disables the periodic repeat

# OPTIONAL: branch to track for auto-update (default 'main').
# GIT_BRANCH=main

# OPTIONAL: how long a job may sit in the CUPS queue before we treat the
# printer as stuck. With raw queues + thermal printers, CUPS often can't
# detect paper-out / jam directly — the queue just stops draining, and this
# threshold catches that. Set to 0 to disable. Default 30s, calibrated for
# thermal receipt printers (jobs normally complete in under 5s).
# STUCK_JOB_THRESHOLD_MS=30000

# OPTIONAL: periodic probe interval — submits a tiny test print at this
# cadence so the stuck-queue detector also catches problems during slow
# hours when no real orders are flowing. Each probe is a single newline
# (~3mm of paper feed on a thermal printer). 0 disables. Default 5 min.
# PROBE_INTERVAL_MS=300000

# OPTIONAL: where to write the local NDJSON order log. Default ./orders.log.
# LOG_FILE=/var/log/esmkt-print/orders.log
